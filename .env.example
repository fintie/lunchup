# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Connection
# For local: mongodb://localhost:27017/lunchup
# For Atlas: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/lunchup?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/lunchup

# JWT Secret (use a long random string in production)
JWT_SECRET=lunchup_secret_key_2024_very_secure_random_string_abc123xyz

# CORS Origin (comma-separated URLs for production)
CORS_ORIGIN=http://localhost:3000

ANTHROPIC_API_KEY=your_anthropic_api_key_here

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/github/callback

# Frontend URL (used by backend to redirect after GitHub OAuth)
# For local: http://localhost:3000
# For production: https://your-frontend.onrender.com
FRONTEND_URL=http://localhost:3000

