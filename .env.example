# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Connection
# For local: mongodb://localhost:27017/lunchup
# For Atlas: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/lunchup?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/lunchup

# JWT Secret (use a long random string in production)
JWT_SECRET=lunchup_secret_key_2024_very_secure_random_string_abc123xyz

# CORS Origin (comma-separated URLs for production)
CORS_ORIGIN=http://localhost:3000

# Optional: event registrations WhatsApp destination number in international format
# Example: 61412345678
WHATSAPP_EVENT_NUMBER=

# Meta WhatsApp Cloud API conversational webhook settings
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v20.0
