# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Connection
# For local: mongodb://localhost:27017/lunchup
# For Atlas: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/lunchup?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/lunchup

# JWT Secret (use a long random string in production)
JWT_SECRET=lunchup_secret_key_2024_very_secure_random_string_abc123xyz

# CORS Origin (comma-separated URLs for production)
CORS_ORIGIN=http://localhost:3000

# Optional: event registrations WhatsApp destination number in international format
# Example: 61412345678
WHATSAPP_EVENT_NUMBER=

# Event source API keys
# Eventbrite expects a private OAuth token usable with the v3 API.
EVENTBRITE_API_KEY=
# Optional: use this to sync from a specific Eventbrite organization. If omitted, sync uses /users/me/events.
EVENTBRITE_ORGANIZATION_ID=
MEETUP_API_KEY=
LUMA_API_KEY=
HUMANITIX_API_KEY=
# Optional: how many future days each event sync should import
EVENT_SYNC_LOOKAHEAD_DAYS=60
# Optional: comma-separated country filters. Leave blank to import all provider events.
EVENT_SYNC_COUNTRIES=
# Optional: max paginated pages to fetch where a provider supports page numbers
EVENT_SYNC_MAX_PAGES=20
# Optional: fetch/map providers without writing to MongoDB
EVENTS_DRY_RUN=false

# Meta WhatsApp Cloud API conversational webhook settings
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v20.0
