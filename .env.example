# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Connection
# For local: mongodb://localhost:27017/lunchup
# For Atlas: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/lunchup?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/lunchup

# JWT Secret (use a long random string in production)
JWT_SECRET=lunchup_secret_key_2024_very_secure_random_string_abc123xyz

# CORS Origin (comma-separated URLs for production)
CORS_ORIGIN=http://localhost:3000

# Optional: event registrations WhatsApp destination number in international format
# Example: 61412345678
WHATSAPP_EVENT_NUMBER=

# Event source API keys
# Eventbrite expects a private OAuth token usable with the v3 API.
EVENTBRITE_API_KEY=
# Optional: use this to sync from a specific Eventbrite organization. If omitted, sync uses /users/me/events.
EVENTBRITE_ORGANIZATION_ID=
MEETUP_API_KEY=
LUMA_API_KEY=
HUMANITIX_API_KEY=
# Optional: how many future days each event sync should import
EVENT_SYNC_LOOKAHEAD_DAYS=60
# Optional: comma-separated country filters. Leave blank to import all provider events.
EVENT_SYNC_COUNTRIES=
# Optional: max paginated pages to fetch where a provider supports page numbers
EVENT_SYNC_MAX_PAGES=20
# Optional: fetch public Luma discovery pages such as /sydney and keep tech-matching events
LUMA_DISCOVERY_ENABLED=true
LUMA_DISCOVERY_SLUGS=sydney
LUMA_DISCOVERY_TECH_KEYWORDS=ai,artificial intelligence,machine learning,ml,startup,founder,engineering,developer,software,code,coding,cloud,data,product,tech,technology,web3,blockchain,crypto,cyber,security,hackathon,notion,cursor,claude,qwen,codex,ar,robotics
# Optional: fetch public Meetup Sydney technology pages without an API key
MEETUP_DISCOVERY_ENABLED=true
MEETUP_DISCOVERY_URLS=https://www.meetup.com/en-AU/find/au--sydney/technology/
# Optional: fetch public Humanitix Sydney marketplace pages and keep tech-matching events
HUMANITIX_DISCOVERY_ENABLED=true
HUMANITIX_DISCOVERY_URLS=https://humanitix.com/au
# Optional: fetch/map providers without writing to MongoDB
EVENTS_DRY_RUN=false

# Meta WhatsApp Cloud API conversational webhook settings
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v20.0
